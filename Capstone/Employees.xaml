<Window x:Class="Capstone.Employees"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Management" Height="740" Width="950" WindowState="Maximized" ResizeMode="CanResize"
        MinHeight="450" MinWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Background="White" Height="599">

            <!-- Basic Information -->

            <!-- Employment Details -->
            <GroupBox Header="New Employee" Height="144">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Full Name:" Grid.Row="0" Grid.Column="0"/>
                    <TextBox x:Name="txtFullName" Grid.Row="0" Grid.Column="1"/>

                    <TextBlock Text="Phone Number:" Grid.Row="0" Grid.Column="2"/>
                    <TextBox x:Name="txtPhone" Grid.Row="0" Grid.Column="3"/>

                    <TextBlock Text="Nickname / Barber Name:" Grid.Row="1" Grid.Column="0"/>
                    <TextBox x:Name="txtNickname" Grid.Row="1" Grid.Column="1"/>

                    <TextBlock Text="Email:" Grid.Row="1" Grid.Column="2"/>
                    <TextBox x:Name="txtEmail" Grid.Row="1" Grid.Column="3"/>

                    <TextBlock Text="Address:" Grid.Row="2" Grid.Column="0"/>
                    <TextBox x:Name="txtAddress" Grid.Row="2" Grid.Column="1"/>

                    <TextBlock Text="Emergency Contact:" Grid.Row="2" Grid.Column="2"/>
                    <TextBox x:Name="txtEmergency" Grid.Row="2" Grid.Column="3"/>

                    <TextBlock Text="Birthday / Age:" Grid.Row="3" Grid.Column="0"/>
                    <DatePicker x:Name="dpBirthday" Grid.Row="3" Grid.Column="1"/>
                </Grid>
            </GroupBox>

            <!-- Employment Details -->
            <GroupBox Header="Employment Details" Margin="5" Height="160">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Employee ID:" Grid.Row="0" Grid.Column="0"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Height="26" VerticalAlignment="Top">
                        <TextBox x:Name="txtEmployeeID" Width="120" Height="26"/>
                        <Button x:Name="btnGenerateID" Content="Generate" Click="btnGenerateID_Click" Margin="5,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Duty Schedule:" Grid.Row="0" Grid.Column="2"/>
                    <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top">
                        <StackPanel>
                            <CheckBox x:Name="chkMonday" Content="Monday"/>
                            <CheckBox x:Name="chkTuesday" Content="Tuesday"/>
                            <CheckBox x:Name="chkWednesday" Content="Wednesday"/>
                        </StackPanel>
                        <StackPanel Margin="20,0,0,0">
                            <CheckBox x:Name="chkThursday" Content="Thursday"/>
                            <CheckBox x:Name="chkFriday" Content="Friday"/>
                            <CheckBox x:Name="chkSaturday" Content="Saturday"/>
                        </StackPanel>
                        <StackPanel Margin="20,0,0,0">
                            <CheckBox x:Name="chkSunday" Content="Sunday"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Role ComboBox -->
                    <TextBlock Text="Role:" Grid.Row="1" Grid.Column="0"/>
                    <ComboBox x:Name="cbRole" Grid.Row="1" Grid.Column="1" Width="180">
                        <ComboBoxItem Content="Barber"/>
                        <ComboBoxItem Content="Assistant"/>
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="Cashier"/>
                        <ComboBoxItem Content="Manager"/>
                    </ComboBox>

                    <!-- Employment Status ComboBox -->
                    <TextBlock Text="Employment Status:" Grid.Row="1" Grid.Column="2"/>
                    <ComboBox x:Name="cbEmploymentStatus" Grid.Row="1" Grid.Column="2" Width="180" Grid.ColumnSpan="2" Margin="149,1,71,23" Grid.RowSpan="2">
                        <ComboBoxItem Content="Full-time"/>
                        <ComboBoxItem Content="Part-time"/>
                        <ComboBoxItem Content="Probationary"/>
                    </ComboBox>

                    <!-- Expertise ComboBox -->
                    <TextBlock Text="Expertise / Specialty:" Grid.Row="2" Grid.Column="0"/>
                    <ComboBox x:Name="cbExpertise" Grid.Row="2" Grid.Column="1" Width="180">
                        <ComboBoxItem Content="Fades"/>
                        <ComboBoxItem Content="Beard Styling"/>
                        <ComboBoxItem Content="Hair Coloring"/>
                        <ComboBoxItem Content="Classic Cuts"/>
                        <ComboBoxItem Content="Shaving"/>
                    </ComboBox>

                    <TextBlock Text="Date Hired:" Grid.Row="2" Grid.Column="2"/>
                    <DatePicker x:Name="dpDateHired" Grid.Row="2" Grid.Column="3"/>
                </Grid>
            </GroupBox>

            <!-- Account Access -->
            <GroupBox Header="Account Access" Margin="5">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Employee ID:" Width="100"/>
                        <TextBox x:Name="txtAccEmployeeID" Width="150"/>
                        <TextBlock Text="Password:" Width="100" Margin="20,0,0,0"/>
                        <PasswordBox x:Name="txtPassword" Width="150"/>
                    </StackPanel>

                    <DataGrid x:Name="dgEmployees" AutoGenerateColumns="False" Height="139" SelectionChanged="dgEmployees_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}"/>
                            <DataGridTextColumn Header="Nickname" Binding="{Binding Nickname}"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}"/>
                            <DataGridTextColumn Header="Birthday" Binding="{Binding Birthday}"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}"/>
                            <DataGridTextColumn Header="Emergency" Binding="{Binding EmergencyContact}"/>
                            <DataGridTextColumn Header="Employee ID" Binding="{Binding EmployeeID}"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}"/>
                            <DataGridTextColumn Header="Expertise" Binding="{Binding Expertise}"/>
                            <DataGridTextColumn Header="Employment Status" Binding="{Binding EmploymentStatus}"/>
                            <DataGridTextColumn Header="Duty Schedule" Binding="{Binding DutySchedule}"/>
                            <DataGridTextColumn Header="Date Hired" Binding="{Binding DateHired}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </GroupBox>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                <Button Content="Save" Width="100" Margin="5" Click="btnSave_Click"/>
                <Button Content="Update" Width="100" Margin="5" Click="btnUpdate_Click"/>
                <Button Content="Delete" Width="100" Margin="5" Click="btnDelete_Click"/>
                <Button Content="Clear" Width="100" Margin="5" Click="btnClear_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
